{
    "name": "c-host/omeka-s-module-internet-archive-inbound-sync",
    "type": "omeka-s-module",
    "description": "Import Internet Archive items into Omeka S with admin UI and background jobs.",
    "license": "GPL-3.0-only",
    "autoload": {
        "psr-4": {
            "InternetArchiveInboundSync\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "InternetArchiveInboundSyncTest\\": "test/"
        }
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "scripts": {
        "test": "phpunit",
        "test:smoke": "php test/smoke.php"
    }
}
